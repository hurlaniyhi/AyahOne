{"number":112,"ayahs":[{"numberInSurah":1,"arabic":" قُلْ هُوَ ٱللَّهُ أَحَدٌ","translation":"Say, \"He is Allāh, [who is] One,","transliteration":"Qul huwa Allahu ahad","page":604},{"numberInSurah":2,"arabic":"ٱللَّهُ ٱلصَّمَدُ","translation":"Allāh, the Eternal Refuge.","transliteration":"Allahu assamad","page":604},{"numberInSurah":3,"arabic":"لَمْ يَلِدْ وَلَمْ يُولَدْ","translation":"He neither begets nor is born,","transliteration":"Lam yalid walam yoolad","page":604},{"numberInSurah":4,"arabic":"وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ","translation":"Nor is there to Him any equivalent.\"","transliteration":"Walam yakun lahu kufuwan ahad","page":604}]}