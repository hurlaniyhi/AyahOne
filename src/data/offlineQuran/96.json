{"number":96,"ayahs":[{"numberInSurah":1,"arabic":" ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ","translation":"Recite in the name of your Lord who created","transliteration":"Iqra/ bi-ismi rabbika allathee khalaq","page":597},{"numberInSurah":2,"arabic":"خَلَقَ ٱلْإِنسَـٰنَ مِنْ عَلَقٍ","translation":"Created man from a clinging substance.","transliteration":"Khalaqa al-insana min AAalaq","page":597},{"numberInSurah":3,"arabic":"ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ","translation":"Recite, and your Lord is the most Generous -","transliteration":"Iqra/ warabbuka al-akram","page":597},{"numberInSurah":4,"arabic":"ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ","translation":"Who taught by the pen","transliteration":"Allathee AAallama bilqalam","page":597},{"numberInSurah":5,"arabic":"عَلَّمَ ٱلْإِنسَـٰنَ مَا لَمْ يَعْلَمْ","translation":"Taught man that which he knew not.","transliteration":"AAallama al-insana ma lamyaAAlam","page":597},{"numberInSurah":6,"arabic":"كَلَّآ إِنَّ ٱلْإِنسَـٰنَ لَيَطْغَىٰٓ","translation":"No! [But] indeed, man transgresses","transliteration":"Kalla inna al-insana layatgha","page":597},{"numberInSurah":7,"arabic":"أَن رَّءَاهُ ٱسْتَغْنَىٰٓ","translation":"Because he sees himself self-sufficient.","transliteration":"An raahu istaghna","page":597},{"numberInSurah":8,"arabic":"إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ","translation":"Indeed, to your Lord is the return.","transliteration":"Inna ila rabbika arrujAAa","page":597},{"numberInSurah":9,"arabic":"أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ","translation":"Have you seen the one who forbids","transliteration":"Araayta allathee yanha","page":597},{"numberInSurah":10,"arabic":"عَبْدًا إِذَا صَلَّىٰٓ","translation":"A servant when he prays?","transliteration":"AAabdan itha salla","page":597},{"numberInSurah":11,"arabic":"أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ","translation":"Have you seen if he is upon guidance","transliteration":"Araayta in kana AAala alhuda","page":597},{"numberInSurah":12,"arabic":"أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ","translation":"Or enjoins righteousness?","transliteration":"Aw amara bittaqwa","page":597},{"numberInSurah":13,"arabic":"أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ","translation":"Have you seen if he denies and turns away -","transliteration":"Araayta in kaththaba watawalla","page":597},{"numberInSurah":14,"arabic":"أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ","translation":"Does he not know that Allāh sees?","transliteration":"Alam yaAAlam bi-anna Allaha yara","page":597},{"numberInSurah":15,"arabic":"كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ","translation":"No! If he does not desist, We will surely drag him by the forelock","transliteration":"Kalla la-in lam yantahi lanasfaAAanbinnasiya","page":597},{"numberInSurah":16,"arabic":"نَاصِيَةٍ كَـٰذِبَةٍ خَاطِئَةٍ","translation":"A lying, sinning forelock.","transliteration":"Nasiyatin kathibatin khati-a","page":597},{"numberInSurah":17,"arabic":"فَلْيَدْعُ نَادِيَهُۥ","translation":"Then let him call his associates;","transliteration":"FalyadAAu nadiyah","page":597},{"numberInSurah":18,"arabic":"سَنَدْعُ ٱلزَّبَانِيَةَ","translation":"We will call the angels of Hell.","transliteration":"SanadAAu azzabaniya","page":597},{"numberInSurah":19,"arabic":"كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب ۩","translation":"No! Do not obey him. But prostrate and draw near [to Allāh].","transliteration":"Kalla la tutiAAhu wasjudwaqtarib","page":597}]}