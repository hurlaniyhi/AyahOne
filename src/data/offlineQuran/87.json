{"number":87,"ayahs":[{"numberInSurah":1,"arabic":" سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى","translation":"Exalt the name of your Lord, the Most High,","transliteration":"Sabbihi isma rabbika al-aAAla","page":591},{"numberInSurah":2,"arabic":"ٱلَّذِى خَلَقَ فَسَوَّىٰ","translation":"Who created and proportioned","transliteration":"Allathee khalaqa fasawwa","page":591},{"numberInSurah":3,"arabic":"وَٱلَّذِى قَدَّرَ فَهَدَىٰ","translation":"And who destined and [then] guided","transliteration":"Wallathee qaddara fahada","page":591},{"numberInSurah":4,"arabic":"وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ","translation":"And who brings out the pasture","transliteration":"Wallathee akhraja almarAAa","page":591},{"numberInSurah":5,"arabic":"فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ","translation":"And [then] makes it black stubble.","transliteration":"FajaAAalahu ghuthaan ahwa","page":591},{"numberInSurah":6,"arabic":"سَنُقْرِئُكَ فَلَا تَنسَىٰٓ","translation":"We will make you recite, [O Muḥammad], and you will not forget,","transliteration":"Sanuqri-oka fala tansa","page":591},{"numberInSurah":7,"arabic":"إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ","translation":"Except what Allāh should will. Indeed, He knows what is declared and what is hidden.","transliteration":"Illa ma shaa Allahuinnahu yaAAlamu aljahra wama yakhfa","page":591},{"numberInSurah":8,"arabic":"وَنُيَسِّرُكَ لِلْيُسْرَىٰ","translation":"And We will ease you toward ease.","transliteration":"Wanuyassiruka lilyusra","page":591},{"numberInSurah":9,"arabic":"فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ","translation":"So remind, if the reminder should benefit;","transliteration":"Fathakkir in nafaAAati aththikra","page":591},{"numberInSurah":10,"arabic":"سَيَذَّكَّرُ مَن يَخْشَىٰ","translation":"He who fears [Allāh] will be reminded.","transliteration":"Sayaththakkaru man yakhsha","page":591},{"numberInSurah":11,"arabic":"وَيَتَجَنَّبُهَا ٱلْأَشْقَى","translation":"But the wretched one will avoid it","transliteration":"Wayatajannabuha al-ashqa","page":591},{"numberInSurah":12,"arabic":"ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ","translation":"[He] who will [enter and] burn in the greatest Fire,","transliteration":"Allathee yasla annaraalkubra","page":591},{"numberInSurah":13,"arabic":"ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ","translation":"Neither dying therein nor living.","transliteration":"Thumma la yamootu feeha walayahya","page":591},{"numberInSurah":14,"arabic":"قَدْ أَفْلَحَ مَن تَزَكَّىٰ","translation":"He has certainly succeeded who purifies himself","transliteration":"Qad aflaha man tazakka","page":591},{"numberInSurah":15,"arabic":"وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ","translation":"And mentions the name of his Lord and prays.","transliteration":"Wathakara isma rabbihi fasalla","page":591},{"numberInSurah":16,"arabic":"بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا","translation":"But you prefer the worldly life,","transliteration":"Bal tu/thiroona alhayata addunya","page":592},{"numberInSurah":17,"arabic":"وَٱلْـَٔاخِرَةُ خَيْرٌ وَأَبْقَىٰٓ","translation":"While the Hereafter is better and more enduring.","transliteration":"Wal-akhiratu khayrun waabqa","page":592},{"numberInSurah":18,"arabic":"إِنَّ هَـٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ","translation":"Indeed, this is in the former scriptures,","transliteration":"Inna hatha lafee assuhufial-oola","page":592},{"numberInSurah":19,"arabic":"صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ","translation":"The scriptures of Abraham and Moses.","transliteration":"Suhufi ibraheema wamoosa","page":592}]}