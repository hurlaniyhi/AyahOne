{"number":88,"ayahs":[{"numberInSurah":1,"arabic":" هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَـٰشِيَةِ","translation":"Has there reached you the report of the Overwhelming [event]?","transliteration":"Hal ataka hadeethu alghashiyat","page":592},{"numberInSurah":2,"arabic":"وُجُوهٌ يَوْمَئِذٍ خَـٰشِعَةٌ","translation":"[Some] faces, that Day, will be humbled,","transliteration":"Wujoohun yawma-ithin khashiAAa","page":592},{"numberInSurah":3,"arabic":"عَامِلَةٌ نَّاصِبَةٌ","translation":"Working [hard] and exhausted.","transliteration":"AAamilatun nasiba","page":592},{"numberInSurah":4,"arabic":"تَصْلَىٰ نَارًا حَامِيَةً","translation":"They will [enter to] burn in an intensely hot Fire.","transliteration":"Tasla naran hamiya","page":592},{"numberInSurah":5,"arabic":"تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍ","translation":"They will be given drink from a boiling spring.","transliteration":"Tusqa min AAaynin aniya","page":592},{"numberInSurah":6,"arabic":"لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ","translation":"For them there will be no food except from a poisonous, thorny plant","transliteration":"Laysa lahum taAAamun illamin dareeAA","page":592},{"numberInSurah":7,"arabic":"لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍ","translation":"Which neither nourishes nor avails against hunger.","transliteration":"La yusminu wala yughnee minjooAA","page":592},{"numberInSurah":8,"arabic":"وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ","translation":"[Other] faces, that Day, will show pleasure.","transliteration":"Wujoohun yawma-ithin naAAima","page":592},{"numberInSurah":9,"arabic":"لِّسَعْيِهَا رَاضِيَةٌ","translation":"With their effort [they are] satisfied","transliteration":"LisaAAyiha radiya","page":592},{"numberInSurah":10,"arabic":"فِى جَنَّةٍ عَالِيَةٍ","translation":"In an elevated garden,","transliteration":"Fee jannatin AAaliya","page":592},{"numberInSurah":11,"arabic":"لَّا تَسْمَعُ فِيهَا لَـٰغِيَةً","translation":"Wherein they will hear no unsuitable speech.","transliteration":"La tasmaAAu feeha laghiya","page":592},{"numberInSurah":12,"arabic":"فِيهَا عَيْنٌ جَارِيَةٌ","translation":"Within it is a flowing spring.","transliteration":"Feeha AAaynun jariya","page":592},{"numberInSurah":13,"arabic":"فِيهَا سُرُرٌ مَّرْفُوعَةٌ","translation":"Within it are couches raised high","transliteration":"Feeha sururun marfooAAa","page":592},{"numberInSurah":14,"arabic":"وَأَكْوَابٌ مَّوْضُوعَةٌ","translation":"And cups put in place","transliteration":"Waakwabun mawdooAAa","page":592},{"numberInSurah":15,"arabic":"وَنَمَارِقُ مَصْفُوفَةٌ","translation":"And cushions lined up","transliteration":"Wanamariqu masfoofa","page":592},{"numberInSurah":16,"arabic":"وَزَرَابِىُّ مَبْثُوثَةٌ","translation":"And carpets spread around.","transliteration":"Wazarabiyyu mabthootha","page":592},{"numberInSurah":17,"arabic":"أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ","translation":"Then do they not look at the camels - how they are created?","transliteration":"Afala yanthuroona ilaal-ibili kayfa khuliqat","page":592},{"numberInSurah":18,"arabic":"وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ","translation":"And at the sky - how it is raised?","transliteration":"Wa-ila assama-i kayfarufiAAat","page":592},{"numberInSurah":19,"arabic":"وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ","translation":"And at the mountains - how they are erected?","transliteration":"Wa-ila aljibali kayfa nusibat","page":592},{"numberInSurah":20,"arabic":"وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ","translation":"And at the earth - how it is spread out?","transliteration":"Wa-ila al-ardi kayfa sutihat","page":592},{"numberInSurah":21,"arabic":"فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌ","translation":"So remind, [O Muḥammad]; you are only a reminder.","transliteration":"Fathakkir innama anta muthakkir","page":592},{"numberInSurah":22,"arabic":"لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ","translation":"You are not over them a controller.","transliteration":"Lasta AAalayhim bimusaytir","page":592},{"numberInSurah":23,"arabic":"إِلَّا مَن تَوَلَّىٰ وَكَفَرَ","translation":"However, he who turns away and disbelieves","transliteration":"Illa man tawalla wakafar","page":592},{"numberInSurah":24,"arabic":"فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ","translation":"Then Allāh will punish him with the greatest punishment.","transliteration":"FayuAAaththibuhu Allahu alAAathabaal-akbar","page":592},{"numberInSurah":25,"arabic":"إِنَّ إِلَيْنَآ إِيَابَهُمْ","translation":"Indeed, to Us is their return.","transliteration":"Inna ilayna iyabahum","page":592},{"numberInSurah":26,"arabic":"ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم","translation":"Then indeed, upon Us is their account.","transliteration":"Thumma inna AAalayna hisabahum","page":592}]}